PORT=5000
CORS_ORIGIN=http://localhost:5173

# SQLite file (relative to prisma/schema location — use file:../dev.db from prisma folder)
DATABASE_URL="file:./dev.db"

# Required in production — use a long random string
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Azure: set CORS_ORIGIN to your frontend URL, e.g. https://your-app.azurestaticapps.net
# App Service injects PORT — leave PORT unset in Azure Configuration or match the site port.
# Production: use PostgreSQL DATABASE_URL and run prisma migrate deploy
