PORT=5000
CORS_ORIGIN=http://localhost:5173

# Local Postgres (native install + scripts/init-henry-db.sql) or Docker Compose — or use Neon (no Docker):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://henry:henry@localhost:5432/henry?schema=public"

# Azure Database for PostgreSQL Flexible Server (SSL required in connection string):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.postgres.database.azure.com:5432/DATABASE?sslmode=require"

# Required in production — use a long random string
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Azure: set CORS_ORIGIN to your Static Web App URL, e.g. https://your-app.azurestaticapps.net
# App Service sets PORT automatically on Linux — you usually omit PORT in Azure Configuration.
# `npm start` runs `prisma migrate deploy` then the API.
